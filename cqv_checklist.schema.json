{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sistm/AI4Reproducibility/blob/main/cqv_checklist.schema.json",
  "title": "AI4R CQV Code-Quality Checklist",
  "description": "Schema for the machine-checkable code-quality checklist driving the CQV agent.",
  "type": "object",
  "required": ["version", "last_updated", "categories", "check_types", "severities", "items"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "also_enforces": {
      "type": "array",
      "description": "Reproducibility-checklist items the CQV agent is responsible for running.",
      "items": {
        "type": "object",
        "required": ["id", "note"],
        "additionalProperties": false,
        "properties": {
          "id":   { "type": "string", "pattern": "^(bj-\\d{2}|audit)-[a-z0-9-]+$" },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "scoring": {
      "type": "object",
      "required": ["formula", "bands"],
      "additionalProperties": false,
      "properties": {
        "formula": { "type": "string", "minLength": 1 },
        "notes":   { "type": "string", "minLength": 1 },
        "bands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["range", "classification", "action"],
            "additionalProperties": false,
            "properties": {
              "range":          { "type": "string", "pattern": "^\\d+-\\d+$" },
              "classification": { "type": "string", "minLength": 1 },
              "action":         { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id":   { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "check_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "enum": ["static", "dynamic", "llm"] },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "severities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "enum": ["critical", "major", "minor", "suggestion"] },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/checklistItem" }
    }
  },

  "$defs": {
    "checklistItem": {
      "type": "object",
      "required": [
        "id", "category", "description",
        "check_type", "tool_id", "severity",
        "evidence_required", "applies_to"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cqv-(syntax|struct|data|stat|perf|sec|doc|test|dep|exec)-[a-z0-9-]+$",
          "description": "cqv-<area>-<slug> where area matches one of the canonical sections."
        },
        "category": {
          "type": "string",
          "enum": [
            "syntax", "struct", "data", "stat", "perf",
            "sec", "doc", "test", "dep", "exec"
          ]
        },
        "description": { "type": "string", "minLength": 10 },
        "check_type":  { "type": "string", "enum": ["static", "dynamic", "llm"] },
        "tool_id": {
          "type": "string",
          "pattern": "^(check|judge|run)_[a-z][a-z0-9_]*$"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "major", "minor", "suggestion"]
        },
        "evidence_required": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 5 }
        },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["any", "r", "python", "stata", "julia", "matlab"]
          }
        },
        "cross_reference": {
          "type": "string",
          "pattern": "^(bj-\\d{2}|audit)-[a-z0-9-]+$",
          "description": "Optional id of a related item in checklist.yaml."
        }
      },
      "allOf": [
        {
          "if":   { "properties": { "check_type": { "const": "static" } } },
          "then": { "properties": { "tool_id": { "pattern": "^check_" } } }
        },
        {
          "if":   { "properties": { "check_type": { "const": "llm" } } },
          "then": { "properties": { "tool_id": { "pattern": "^judge_" } } }
        },
        {
          "if":   { "properties": { "check_type": { "const": "dynamic" } } },
          "then": { "properties": { "tool_id": { "pattern": "^run_" } } }
        }
      ]
    }
  }
}
